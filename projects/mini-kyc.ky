; mini-kyc.ky - Self-hosting KY compiler (Phase 1)
; Compiles .ky source -> Windows x64 PE executable
; Phase 1: handles opcodes 40 FF 30 60 65 66 70 71 41

; String definitions
12 s696e7075742e6b7900
12 s6f75747075742e65786500

; Embedded PE template blob (34816 = 0x8800 bytes)
13 4000 

; Startup code blob (79 bytes at data offset 0xcc00)
; VirtualAlloc state array -> R15, GetStdHandle stdout -> R14
13 cc00 s48b9000000000000000048ba000002000000000049b8003000000000000049b94000000000000000ff150a4000004989c7488d05c83f00004989474048b9f5ffffffffffffffff15bc3f00004989c6

; === Compiler initialization ===
; Read input.ky -> state_0A (buffer ptr), state_0B (file size)
50 0A 00
; Allocate 0x40000-byte output buffer -> state_02
20 02 00040000
; Initialize scanner state variables
30 0e 00 ; code_offset = 0
60 0c 0a ; read_ptr = input_buf
60 0d 0b ; end_ptr = file_size
68 0d 0c ; end_ptr += read_ptr (= buf + size)
30 10 00 ; scanner_state = 0
30 11 00 ; acc = 0
30 12 00 ; digit_count = 0
30 13 00 ; opcode = 0
30 14 00 ; arg_index = 0

; Copy embedded PE template to output buffer
84 02 4000 8800

; === H_30 emitter initialization ===
; Setup write base: state_03 = output_buf + 0x400 (= .text file offset)
60 03 02
61 03 400
; Allocate handler offset table (256 entries x4 bytes = 1024) -> state_04
20 04 400
; Allocate fixup hh array (max 256 fixups x4 bytes) -> state_05
20 05 400
; Allocate fixup patch-position array -> state_06
20 06 400
; Initialize emitter state: fixup_count=0, first_handler_flag=0
30 07 00 ; fixup_count = 0
30 09 00 ; first_handler_flag = 0
; Copy startup code (68 bytes) to output .text section (at offset 0)
60 4c 03
84 4C cc00 4F
61 0e 4f ; advance code_offset by 79 (startup size)

; Run scanner -> emitter
41 01 ; call H_01 main scan loop
; Write output.exe
51 02 01 0E

